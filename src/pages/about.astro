---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About Dr. Anjali Rana - Researcher in evolutionary genetics, genomics, and microbiome" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>About Me</h1>
				<p class="tagline">Researcher · Educator · Science Communicator</p>
			</section>

			<section class="content">
				<h2>Background</h2>
				<p>
					I'm Dr. Anjali Rana, a researcher specializing in evolutionary genetics, genomics, and microbiome studies. My work focuses on understanding host-microbe interactions through advanced sequencing techniques and computational analysis.
				</p>

				<h2>Research Focus</h2>
				<p>
					My research explores the intricate relationships between hosts and their microbial communities. I have extensive experience in genome assembly, microbiome analysis workflows, and developing R-based computational pipelines for biological data.
				</p>

				<h2>Beyond Research</h2>
				<p>
					I'm passionate about making science accessible. Through this platform, I simplify complex scientific concepts and share practical guidance for students and early-career researchers navigating their PhD journey.
				</p>

				<h2>Connect</h2>
				<p>
					Feel free to reach out for collaborations, questions about my research, or guidance on academic matters.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 720px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.content {
		padding: 1rem 0;
	}

	.content h2 {
		font-size: 1.4rem;
		color: var(--accent-dark);
		margin: 2rem 0 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid rgb(var(--gray-light));
	}

	.content h2:first-child {
		margin-top: 0;
	}

	.content p {
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2rem;
		}
	}
</style>
