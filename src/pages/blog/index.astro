---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Articles on research, bioinformatics, and PhD guidance" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Blog</h1>
				<p class="tagline">Insights on research, bioinformatics workflows, and academic life</p>
			</section>

			<section class="posts">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-card">
						{post.data.heroImage && (
							<div class="post-image">
								<Image width={720} height={360} src={post.data.heroImage} alt="" />
							</div>
						)}
						<div class="post-content">
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-description">{post.data.description}</p>
							<p class="post-date">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</div>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 960px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2.5rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.posts {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.post-card {
		display: flex;
		gap: 1.5rem;
		padding: 1.25rem;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(var(--gray), 20%);
		border-color: var(--accent);
	}

	.post-image {
		flex-shrink: 0;
		width: 200px;
		height: 120px;
		overflow: hidden;
		border-radius: 8px;
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
	}

	.post-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.post-title {
		font-size: 1.25rem;
		color: rgb(var(--gray-dark));
		margin: 0 0 0.5rem;
		line-height: 1.3;
		transition: color 0.2s ease;
	}

	.post-card:hover .post-title {
		color: var(--accent);
	}

	.post-description {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin: 0 0 0.5rem;
		line-height: 1.5;
	}

	.post-date {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2rem;
		}

		.post-card {
			flex-direction: column;
			gap: 1rem;
		}

		.post-image {
			width: 100%;
			height: 180px;
		}
	}
</style>
