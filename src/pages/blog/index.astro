---
import { sanityClient } from "sanity:client";
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

// GROQ query to fetch posts
const posts = await sanityClient.fetch(`
  *[_type == "post" && defined(slug.current)] | order(publishedAt desc) {
    _id,
    title,
    slug,
    publishedAt,
    excerpt,
    mainImage {
      asset->{
        _id,
        url
      }
    }
  }
`);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Articles on research, bioinformatics, and PhD guidance" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Blog</h1>
				<p class="tagline">Insights on research, bioinformatics workflows, and academic life</p>
			</section>

			<section class="content">
				{posts.length === 0 ? (
					<p class="no-posts">Blog posts coming soon. Content will be managed through Sanity CMS.</p>
				) : (
					<div class="posts">
						{posts.map((post: { _id: string; title: string; slug: { current: string }; publishedAt: string; excerpt?: string; mainImage?: { asset: { url: string } } }) => (
							<a href={`/blog/${post.slug.current}/`} class="post-card">
								{post.mainImage?.asset?.url && (
									<div class="post-image">
										<img src={post.mainImage.asset.url} alt={post.title} />
									</div>
								)}
								<div class="post-content">
									<h2 class="post-title">{post.title}</h2>
									{post.excerpt && <p class="post-description">{post.excerpt}</p>}
									{post.publishedAt && (
										<p class="post-date">
											<FormattedDate date={new Date(post.publishedAt)} />
										</p>
									)}
								</div>
							</a>
						))}
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 720px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.content {
		padding: 1rem 0;
	}

	.no-posts {
		text-align: center;
		color: rgb(var(--gray));
		padding: 2rem 0;
	}

	.posts {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.post-card {
		display: flex;
		gap: 1.5rem;
		padding: 1.25rem;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 24px rgba(var(--gray), 20%);
		border-color: var(--accent);
	}

	.post-image {
		flex-shrink: 0;
		width: 200px;
		height: 120px;
		overflow: hidden;
		border-radius: 8px;
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.post-title {
		font-size: 1.25rem;
		color: rgb(var(--gray-dark));
		margin: 0 0 0.5rem;
		line-height: 1.3;
		transition: color 0.2s ease;
	}

	.post-card:hover .post-title {
		color: var(--accent);
	}

	.post-description {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		margin: 0 0 0.5rem;
		line-height: 1.5;
	}

	.post-date {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2rem;
		}

		.post-card {
			flex-direction: column;
			gap: 1rem;
		}

		.post-image {
			width: 100%;
			height: 180px;
		}
	}
</style>
