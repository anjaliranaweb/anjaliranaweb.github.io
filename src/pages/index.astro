---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const tiles = [
	{ emoji: '🧬', title: 'Molecular Biology Protocols', href: '/blog' },
	{ emoji: '🦠', title: 'Microbiome Analysis Workflows', href: '/blog' },
	{ emoji: '📊', title: 'R & Bioinformatics Guides', href: '/blog' },
	{ emoji: '🎓', title: 'PhD Guidance & Resources', href: '/blog' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Dr. Anjali Rana</h1>
				<p class="tagline">Researcher in Evolutionary Genetics, Genomics & Microbiome</p>
			</section>

			<section class="about">
				<p>
					I work on understanding host-microbe interactions using sequencing and data analysis, with experience in genome assembly, microbiome studies, and R-based workflows.
				</p>
				<p>
					Beyond research, I simplify PhD life and complex scientific concepts for a growing community of students and researchers.
				</p>
			</section>

			<section class="resources">
				<h2>What You'll Find Here</h2>
				<div class="tiles">
					{tiles.map((tile) => (
						<a href={tile.href} class="tile">
							<span class="tile-emoji">{tile.emoji}</span>
							<span class="tile-title">{tile.title}</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 1100px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.2rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.about {
		max-width: 720px;
		margin: 0 auto 2.5rem;
	}

	.about p {
		text-align: center;
		color: rgb(var(--gray-dark));
	}

	.resources {
		margin-bottom: 2rem;
	}

	.resources h2 {
		text-align: center;
		font-size: 1.5rem;
		color: rgb(var(--black));
		margin-bottom: 1.5rem;
	}

	.tiles {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}

	.tile {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 1.5rem 1rem;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		box-shadow: 0 2px 8px rgba(var(--gray), 15%);
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.tile:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(var(--gray), 25%);
		border-color: var(--accent);
	}

	.tile-emoji {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}

	.tile-title {
		font-size: 1rem;
		font-weight: 600;
		color: rgb(var(--gray-dark));
		text-align: center;
	}

	.tile:hover .tile-title {
		color: var(--accent);
	}

	@media (max-width: 600px) {
		.tiles {
			grid-template-columns: 1fr;
		}

		.hero h1 {
			font-size: 2rem;
		}

		.tagline {
			font-size: 1rem;
		}
	}
</style>
