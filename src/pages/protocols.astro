---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Protocols | ${SITE_TITLE}`} description="Laboratory protocols and methodologies" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Protocols</h1>
				<p class="tagline">Laboratory methods and experimental workflows</p>
			</section>

			<section class="content">
				<p>Protocols content coming soon.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 720px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.content {
		padding: 1rem 0;
	}

	.content p {
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2rem;
		}
	}
</style>
