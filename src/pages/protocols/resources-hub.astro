---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Resources Hub | ${SITE_TITLE}`} description="Useful resources, links, and reference materials" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<a href="/protocols" class="back-link">← Back to Protocols</a>
				<h1>📚 Resources Hub</h1>
				<p class="tagline">Useful links, databases, and reference materials</p>
			</section>

			<section class="content">
				<p>Content coming soon.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 1100px;
		max-width: calc(100% - 2em);
	}

	.hero {
		text-align: center;
		padding: 2rem 0 1.5rem;
		border-bottom: 2px solid var(--accent);
		margin-bottom: 2rem;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9rem;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	.hero h1 {
		font-size: 2.5rem;
		color: var(--accent-dark);
		margin-bottom: 0.5rem;
	}

	.tagline {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		margin: 0;
	}

	.content {
		padding: 1rem 0;
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
	}

	.content p {
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2rem;
		}
	}
</style>
