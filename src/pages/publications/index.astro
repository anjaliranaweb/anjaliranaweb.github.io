---
import { sanityClient } from "sanity:client";
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

interface Publication {
_id: string;
title: string;
slug: { current: string };
publishedAt: string;
status?: string;
contributors?: string[];
tags?: string[];
abstract?: string;
pdfUrl?: string;
journal?: string;
doi?: string;
}

const publications: Publication[] = await sanityClient.fetch(`
  *[_type == "publication" && defined(slug.current)] | order(publishedAt desc) {
    _id,
    title,
    slug,
    publishedAt,
    status,
    contributors,
    tags,
    abstract,
    pdfUrl,
    journal,
    doi
  }
`);

const statusColors: Record<string, { bg: string; text: string; border: string }> = {
  'published': { bg: '#dcfce7', text: '#166534', border: '#22c55e' },
  'under-review': { bg: '#fef3c7', text: '#92400e', border: '#f59e0b' },
  'in-preparation': { bg: '#e0e7ff', text: '#3730a3', border: '#6366f1' },
};

const statusLabels: Record<string, string> = {
  'published': 'Published',
  'under-review': 'Under Review',
  'in-preparation': 'In Preparation',
};

function formatDate(dateStr: string): string {
const date = new Date(dateStr);
return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={`Publications | ${SITE_TITLE}`} description="Academic publications and research papers by Dr. Anjali Rana" />
</head>
<body>
<Header />
<main>
<section class="hero">
<h1>Publications</h1>
<p class="tagline">Peer-reviewed research and academic contributions</p>
</section>

<section class="content">
{publications.length === 0 ? (
<p class="no-publications">Publications coming soon. Content will be managed through Sanity CMS.</p>
) : (
<div class="publications-list">
{publications.map((pub) => (
<article class="publication-card">
<div class="publication-header">
<div class="title-row">
<h2 class="publication-title">
<a href={`/publications/${pub.slug.current}/`}>{pub.title}</a>
</h2>
{pub.status && (
<span 
class="status-badge"
style={`background-color: ${statusColors[pub.status]?.bg}; color: ${statusColors[pub.status]?.text}; border-color: ${statusColors[pub.status]?.border}`}
>
{statusLabels[pub.status]}
</span>
)}
</div>
{pub.journal && <p class="journal">{pub.journal}</p>}
</div>

{pub.contributors && pub.contributors.length > 0 && (
<p class="contributors">
{pub.contributors.join(', ')}
</p>
)}

<p class="date">{formatDate(pub.publishedAt)}</p>

{pub.abstract && (
<p class="abstract">{pub.abstract.length > 250 ? pub.abstract.slice(0, 250) + '...' : pub.abstract}</p>
)}

<div class="publication-footer">
{pub.tags && pub.tags.length > 0 && (
<div class="tags">
{pub.tags.map((tag) => (
<span class="tag">{tag}</span>
))}
</div>
)}

<div class="actions">
{pub.pdfUrl && (
<a href={pub.pdfUrl} class="btn btn-pdf" target="_blank" rel="noopener noreferrer">
<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2l5 5h-5V4zm-3 9h4v2h-4v-2zm0 3h4v2h-4v-2zm-2-3H7v-2h1v2zm0 3H7v-2h1v2zm7-3h1v2h-1v-2zm0 3h1v2h-1v-2z"/>
</svg>
PDF
</a>
)}
{pub.doi && (
<a href={`https://doi.org/${pub.doi}`} class="btn btn-doi" target="_blank" rel="noopener noreferrer">
DOI
</a>
)}
</div>
</div>
</article>
))}
</div>
)}
</section>
</main>
<Footer />
</body>
</html>

<style>
main {
width: 1100px;
max-width: calc(100% - 2em);
}

.hero {
text-align: center;
padding: 2rem 0 1rem;
border-bottom: 2px solid var(--accent);
margin-bottom: 2rem;
}

.hero h1 {
font-size: 2.5rem;
color: var(--accent-dark);
margin-bottom: 0.5rem;
}

.tagline {
font-size: 1.1rem;
color: rgb(var(--gray));
margin: 0;
}

.content {
padding: 1rem 0;
}

.no-publications {
text-align: center;
color: rgb(var(--gray));
padding: 2rem 0;
}

.publications-list {
display: flex;
flex-direction: column;
gap: 1.5rem;
}

.publication-card {
padding: 1.5rem;
background: #fff;
border: 1px solid rgb(var(--gray-light));
border-radius: 12px;
box-shadow: 0 2px 12px rgba(var(--gray), 10%);
transition: box-shadow 0.2s ease;
}

.publication-card:hover {
box-shadow: 0 4px 20px rgba(var(--gray), 20%);
}

.publication-header {
margin-bottom: 0.75rem;
}

.title-row {
display: flex;
align-items: flex-start;
gap: 0.75rem;
flex-wrap: wrap;
}

.status-badge {
display: inline-block;
font-size: 0.7rem;
font-weight: 600;
padding: 0.25rem 0.6rem;
border-radius: 4px;
border: 1px solid;
text-transform: uppercase;
letter-spacing: 0.025em;
white-space: nowrap;
margin-top: 0.2rem;
}

.publication-title {
font-size: 1.25rem;
margin: 0 0 0.25rem;
line-height: 1.4;
}

.publication-title a {
color: rgb(var(--gray-dark));
text-decoration: none;
transition: color 0.2s ease;
}

.publication-title a:hover {
color: var(--accent);
}

.journal {
font-size: 0.95rem;
color: var(--accent-dark);
font-style: italic;
margin: 0;
}

.contributors {
font-size: 0.9rem;
color: rgb(var(--gray));
margin: 0 0 0.5rem;
}

.date {
font-size: 0.85rem;
color: rgb(var(--gray));
margin: 0 0 0.75rem;
}

.abstract {
font-size: 0.95rem;
color: rgb(var(--gray-dark));
line-height: 1.6;
margin: 0 0 1rem;
}

.publication-footer {
display: flex;
justify-content: space-between;
align-items: flex-start;
flex-wrap: wrap;
gap: 1rem;
}

.tags {
display: flex;
flex-wrap: wrap;
gap: 0.5rem;
}

.tag {
font-size: 0.75rem;
padding: 0.25rem 0.75rem;
background: rgba(13, 148, 136, 0.1);
color: var(--accent-dark);
border-radius: 20px;
}

.actions {
display: flex;
gap: 0.5rem;
}

.btn {
display: inline-flex;
align-items: center;
gap: 0.35rem;
font-size: 0.85rem;
font-weight: 500;
padding: 0.4rem 0.85rem;
border-radius: 6px;
text-decoration: none;
transition: all 0.2s ease;
}

.btn-pdf {
background: #dc2626;
color: white;
}

.btn-pdf:hover {
background: #b91c1c;
}

.btn-doi {
background: rgb(var(--gray-dark));
color: white;
}

.btn-doi:hover {
background: rgb(var(--black));
}

@media (max-width: 600px) {
.hero h1 {
font-size: 2rem;
}

.publication-footer {
flex-direction: column;
}

.actions {
width: 100%;
}

.btn {
flex: 1;
justify-content: center;
}
}
</style>
